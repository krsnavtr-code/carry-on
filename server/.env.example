# SMTP Configuration for Hostinger Mail
SMTP_HOST=smtp.hostinger.com
SMTP_USER=your-email@carry-on.in
SMTP_PASS=your-smtp-password
EMAIL_FROM_ADDRESS=connect@carry-on.in
EMAIL_FROM_NAME=Carry-On Car Rental
OWNER_EMAIL=connect@carry-on.in

# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database Configuration (if needed)
MONGODB_URI=mongodb://localhost:27017/carryon-car-rental
