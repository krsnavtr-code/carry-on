# SMTP Configuration for Outlook/Office 365
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=connect@carry-on.in
SMTP_PASS=your-outlook-password-or-app-password
EMAIL_FROM_ADDRESS=connect@carry-on.in
EMAIL_FROM_NAME=Carry-On Car Rental
OWNER_EMAIL=connect@carry-on.in

# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database Configuration (if needed)
MONGODB_URI=mongodb://localhost:27017/carryon-car-rental
